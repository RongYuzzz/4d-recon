# OS / editor
.DS_Store
*.swp

# Python caches
**/__pycache__/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/

# Environments
**/.venv/
.env
.env.*

# Build / package artifacts
**/*.egg-info/

# Local data and outputs (keep directory placeholders)
data/*
!data/.gitkeep
outputs/*
!outputs/.gitkeep

# Local artifacts (evidence packs, large binaries)
artifacts/report_packs/*.tar.gz

# Logs / temp
*.log
*.tmp
.tmp_local/

# Local third-party archives
third_party/*.tar.gz

# Local git worktrees
.worktrees/
